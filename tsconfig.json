{
  "compileOnSave": false,
  "compilerOptions": {
    "baseUrl": "./",
    "outDir": "./dist/out-tsc",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "bundler",
    "target": "ES2022",
    "module": "es2022",
    "lib": ["es2022", "dom"],
    "paths": {
      "@model/*": ["server/src/model/*"],
      "@message/*": ["server/src/messages/*"],
    }
  },
  "exclude": ["node_modules"]
}
